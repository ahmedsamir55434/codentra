<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>إنشاء عرض - Codentra Presentations</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/presentations.css">
</head>
<body class="presentations-page">
  <%- include('../partials/header') %>

  <main class="presentations-shell">
    <section class="container presentations-builder-grid">
      <div class="presentations-card">
        <span class="presentations-kicker">AI Builder</span>
        <h1>أنشئ عرضًا جديدًا</h1>
        <p>لديك الآن <strong><%= activeSubscription.remainingCredits %></strong> عملية إنشاء متبقية في هذا الاشتراك.</p>
        <a class="btn btn-secondary" href="/codentra-presentations">العودة للوحة العروض</a>
      </div>

      <form class="presentations-card presentations-form" action="/codentra-presentations/generate" method="POST">
        <% if (error) { %>
          <div class="presentations-flash presentations-flash-error"><%= error %></div>
        <% } %>

        <label class="presentations-field-wide">
          <span>موضوع العرض</span>
          <input type="text" name="topic" required placeholder="مثال: خطة إطلاق منتج جديد">
        </label>

        <label>
          <span>الجمهور</span>
          <input type="text" name="audience" placeholder="مستثمرين، إدارة، عملاء...">
        </label>

        <label>
          <span>الهدف</span>
          <input type="text" name="purpose" placeholder="بيع فكرة، عرض تقرير، شرح منتج...">
        </label>

        <label>
          <span>النبرة</span>
          <select name="tone">
            <option value="احترافية">احترافية</option>
            <option value="رسمية">رسمية</option>
            <option value="تسويقية">تسويقية</option>
            <option value="مختصرة">مختصرة</option>
          </select>
        </label>

        <label>
          <span>اللغة</span>
          <select name="language">
            <option value="ar">العربية</option>
            <option value="en">English</option>
          </select>
        </label>

        <label>
          <span>عدد الشرائح</span>
          <input type="number" name="slideCount" min="4" max="12" value="7">
        </label>

        <button type="submit" class="btn btn-primary btn-full">إنشاء العرض الآن</button>
      </form>
    </section>
  </main>

  <%- include('../partials/footer') %>
</body>
</html>
